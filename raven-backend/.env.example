# =========================================================================
# Raven Backend Environment Configuration Template
# Copy this file to '.env' and populate with your actual production keys.
# =========================================================================

# --- NestJS Web Application Core ---
PORT=5000
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000,https://raven.app # Comma-separated list of CORS allowed origins

# --- Monnify Digital Wallet Sandbox/Production API Keys ---
# Retrieve these credentials from your Monnify Developer Dashboard (https://monnify.com)
APIKEY=MK_PROD_YOUR_ACTUAL_MONNIFY_API_KEY
Secret_Key=SEC_PROD_YOUR_ACTUAL_MONNIFY_SECRET_KEY
Contract_Code=your_contract_code_here
Monnify_Source_Account=your_monnify_source_settlement_account_number

# --- Africa's Talking Outbound Call Bridging Credentials ---
# Retrieve these credentials from your Africa's Talking Portal (https://africastalking.com)
AT_API_KEY=atsk_your_actual_africas_talking_api_key_here
AT_USERNAME=your_africas_talking_username_here # Use 'sandbox' for testing local integrations
AT_VIRTUAL_NUMBER=+2347000000000            # Your provisioned virtual dial-in/out number
USER_PHONE_NUMBER=+2348000000000            # Simulated or actual primary User Phone Number
DRIVER_PHONE_NUMBER=+2348000000000          # Simulated or actual driver endpoint phone number
