# Raven Frontend (User App) Environment Variables
# Copy to .env for local dev. Never commit real .env files.
# For production (Vercel etc): configure these as build environment variables prefixed VITE_

# Backend API base URL (include /api suffix)
VITE_API_BASE=http://localhost:5000/api

# WebSocket base (no trailing slash, no /booking)
VITE_WS_BASE=http://localhost:5000

# Example production:
# VITE_API_BASE=https://api.raven.transit.example.com/api
# VITE_WS_BASE=https://api.raven.transit.example.com
